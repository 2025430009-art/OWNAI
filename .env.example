# Server
PORT=3000
NODE_ENV=development

# Per-capability model sources (QVAC registry constant or path/URL)
DEFAULT_MODEL_SRC=LLAMA_3_2_1B_INST_Q4_0
LLM_MODEL_SRC=LLAMA_3_2_1B_INST_Q4_0
EMBEDDINGS_MODEL_SRC=
WHISPER_MODEL_SRC=
TTS_MODEL_SRC=
DIFFUSION_MODEL_SRC=
NMT_MODEL_SRC=
OCR_MODEL_SRC=
CLASSIFICATION_MODEL_SRC=
VLA_MODEL_SRC=
MODEL_PATH=./models
MODEL_CTX_SIZE=2048

# Auth
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Database (PostgreSQL)
DATABASE_URL=postgresql://CHANGE_ME_USER:CHANGE_ME_PASSWORD@localhost:5432/ownai
# MongoDB (PromptToVideo jobs/history metadata)
MONGODB_URI=

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10
INFERENCE_RATE_LIMIT_MAX=30
COMPUTE_RATE_LIMIT_MAX=60

# Security (set REQUIRE_API_AUTH=true in production deployments)
REQUIRE_API_AUTH=false
API_KEY=
ADMIN_USER_IDS=

# RAG
MAX_RAG_DOCS_PER_USER=100

# CORS (comma-separated origins allowed to call the API)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,https://2025430009-art.github.io

# Frontend API URL (optional — baked into GitHub Pages build via VITE_API_URL secret)
# Local dev default: http://localhost:3000 (used when running frontend on localhost)
VITE_API_URL=http://localhost:3000
