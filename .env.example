# Server
PORT=3000
NODE_ENV=development

# Per-capability model sources (QVAC registry constant or path/URL)
DEFAULT_MODEL_SRC=LLAMA_3_2_1B_INST_Q4_0
LLM_MODEL_SRC=LLAMA_3_2_1B_INST_Q4_0
EMBEDDINGS_MODEL_SRC=
WHISPER_MODEL_SRC=
TTS_MODEL_SRC=
DIFFUSION_MODEL_SRC=
NMT_MODEL_SRC=
OCR_MODEL_SRC=
CLASSIFICATION_MODEL_SRC=
VLA_MODEL_SRC=
MODEL_PATH=./models
MODEL_CTX_SIZE=2048

# Auth
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Database (PostgreSQL)
DATABASE_URL=postgresql://ownai:ownai@localhost:5432/ownai

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:5173

# Frontend API URL (for Vite)
VITE_API_URL=http://localhost:3000
